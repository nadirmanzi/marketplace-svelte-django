# Django Marketplace Environment Configuration Template
# Copy this file to .env.local (for development) or .env.production (for production)
# and update the values according to your environment.
#
# SECURITY WARNING: Never commit .env.local or .env.production to git!

# -----------------------------------------------------------------------------
# Core Settings
# -----------------------------------------------------------------------------
DEBUG=True
SECRET_KEY=django-insecure-CHANGE-THIS-IN-PRODUCTION
ALLOWED_HOSTS=localhost,127.0.0.1,api.localhost,backend
ENVIRONMENT=local

# -----------------------------------------------------------------------------
# Frontend Integration
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Local: Leave blank/commented to use SQLite (default).
# Production: Use PostgreSQL.
# DATABASE_URL=postgres://nadirmanzi:manzi200@localhost:5432/marketplace

POSTGRES_DB=marketplace
POSTGRES_USER=nadirmanzi
POSTGRES_PASSWORD=manzi200
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Email Configuration
# -----------------------------------------------------------------------------
# Local: Console backend is default.
# Production: SMTP settings required.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=Marketplace <noreply@example.com>

# -----------------------------------------------------------------------------
# Security & SSL (Production Only)
# -----------------------------------------------------------------------------
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# -----------------------------------------------------------------------------
# Redis / Cache (Optional)
# -----------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379/1

# -----------------------------------------------------------------------------
# AllAuth / Headless
# -----------------------------------------------------------------------------
# HEADLESS_FRONTEND_URLS are derived from FRONTEND_URL automatically.

DJANGO_SUPERUSER_EMAIL=nadir@gmail.com
DJANGO_SUPERUSER_PASSWORD=manzi200
DJANGO_SUPERUSER_TELEPHONE=+250786802977
DJANGO_SUPERUSER_FULL_NAME="Nadir Manzi"